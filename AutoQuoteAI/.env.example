# ============================================================
# AutoQuoteAI — environment configuration
# Copy to .env:  cp .env.example .env   (PowerShell: Copy-Item .env.example .env)
# Everything works locally WITHOUT the external keys below —
# WhatsApp, Stripe and the LLM all fall back to safe stubs.
# ============================================================

# ---------- Core ----------
NODE_ENV=development

# ---------- Datastores (match docker-compose.yml) ----------
DATABASE_URL=postgresql://autoquote:autoquote@localhost:5432/autoquoteai?schema=public
REDIS_URL=redis://localhost:6379

# ---------- Object storage (quote docs, inbound media) ----------
# Local filesystem is used when LOCAL_STORAGE_DIR is set (default dev mode).
LOCAL_STORAGE_DIR=./storage

# ---------- URLs / ports ----------
WEB_URL=http://localhost:3000
API_PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# ---------- Security ----------
# Long random string — session token signing.
AUTH_SECRET=change-me-to-a-long-random-string
# 32+ char secret — encrypts tenant WhatsApp access tokens at rest (AES-256-GCM).
TOKEN_ENCRYPTION_KEY=change-me-to-a-long-random-token-encryption-key

# ============================================================
# WhatsApp — Meta Cloud API
# Leave WHATSAPP_DEV_ACCESS_TOKEN empty to use the console stub provider.
# Set it (any non-empty value) to switch to the real Meta Cloud API,
# then connect a real number per-tenant from the dashboard.
# ============================================================
WHATSAPP_DEV_ACCESS_TOKEN=
# Token you invent; must match the value you enter in Meta's webhook setup.
WHATSAPP_VERIFY_TOKEN=autoquote-dev-verify-token
# App Secret from Meta > App > Settings > Basic. Enables webhook signature
# verification (enforced when NODE_ENV=production).
WHATSAPP_APP_SECRET=
# Graph API version (optional; defaults to v21.0 in code).
WHATSAPP_GRAPH_VERSION=v21.0

# ============================================================
# AI / LLM  (optional — falls back to deterministic rules if unset)
# Set ONE provider. Anthropic is used if both are present.
# ============================================================
LLM_PROVIDER=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ============================================================
# Stripe billing (optional — offline stub used when unset)
# ============================================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_SCALE=
